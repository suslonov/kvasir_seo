# DataForSEO credentials (get these from your DataForSEO API dashboard)
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# Use the sandbox first, switch to https://api.dataforseo.com only after sandbox works.
DATAFORSEO_BASE_URL=https://sandbox.dataforseo.com

# Quizly
QUIZLY_BASE_URL=https://quizly.pub

# Defaults used when a market is not specified explicitly.
# 2840 = United States, 2376 = Israel, 2643 = Russia, 2826 = United Kingdom
DEFAULT_LOCATION_CODE=2840
DEFAULT_LANGUAGE_CODE=en
DEFAULT_LIMIT=1000

# Cost limiter: hard ceiling on the number of billable DataForSEO calls per run.
MAX_API_CALLS_PER_RUN=200
